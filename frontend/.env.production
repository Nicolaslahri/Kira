# Production build (vite build) — the backend serves this bundle SAME-ORIGIN in
# the Docker image, so the API is a relative path (no host/port, no CORS).
# Dev (`vite`) ignores this file and falls back to the cross-origin default in
# lib/api.ts (http://127.0.0.1:8000/api/v1).
VITE_API_BASE=/api/v1
