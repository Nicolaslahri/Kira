# ── Secrets — NEVER commit ────────────────────────────────────────────
.env
.env.*
*.env
!.env.example
backend/.env
backend/.env.*
# NOT a secret: the production build's same-origin API base (VITE_API_BASE=
# /api/v1). The Docker image's `vite build` needs it, so it must be tracked.
!frontend/.env.production

# ── Python ────────────────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
*.pyd
*.egg-info/
.venv/
venv/
env/
.pytest_cache/
.mypy_cache/
.ruff_cache/
build/
dist/
*.egg

# ── Node / Vite frontend ──────────────────────────────────────────────
node_modules/
dist/
dist-ssr/
*.local
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ── SQLite DB + WAL files (user data; regenerable via re-scan) ───────
*.db
*.db-journal
*.db-wal
*.db-shm
kira.db
backend/kira.db

# ── Provider caches (regenerable; large; AniDB title dump is ~20MB) ──
backend/.cache/
.cache/

# ── Bundled runtime binaries (ffmpeg ~195MB; provisioned at runtime by
#    ffmpeg_setup.py — never source, and over GitHub's 100MB limit) ─────
backend/tools/

# ── Portable embedded-ID index (per-machine user data; regenerable;
#    contains local/NAS file paths — see xattr_store.py) ───────────────
kira-id-index.json
backend/kira-id-index.json

# ── Editor / IDE / OS ─────────────────────────────────────────────────
.vscode/*
!.vscode/extensions.json
.idea/
.DS_Store
Thumbs.db
*.swp
*.swo
*~

# ── Local agent / editor state (per-machine; not for the public repo) ──
.claude/
.kira-cleanup-backup-*/
*.bak
.ui-design/

# ── Vendored UI reference (a third-party Next.js starter kept locally for
#    design reference; not part of Kira and not for the repo) ────────────
untitledui-nextjs-starter-kit/

# ── Recovered planning journal (local working notes; not for the repo) ──
PLAN.md

# ── User-local test fixtures the project doesn't ship ────────────────
# (test-media/ has empty placeholder files for parser fixtures —
#  keep them; they're tiny and useful for `pytest`. If you ever add
#  REAL media files there, uncomment the next line.)
# test-media/

# ── Full generated One Pace pack (the canonical copy is hosted at
#    github.com/Nicolaslahri/one-pace-for-kira; only the minimal
#    one-pace.example.json belongs in this repo) ───────────────────────
docs/examples/one-pace.json
